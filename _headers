# ═══════════════════════════════════════════════════════════
# Cloudflare Pages — Headers per PWA
# ═══════════════════════════════════════════════════════════

# Service Worker — mai in cache, altrimenti gli aggiornamenti non arrivano
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Content-Type: application/javascript; charset=utf-8

# Manifest — breve cache, refresh frequente
/manifest.json
  Cache-Control: public, max-age=3600
  Content-Type: application/manifest+json; charset=utf-8

# Icone — cache lunga (cambiano solo con nuova versione)
/assets/icons/*
  Cache-Control: public, max-age=604800, immutable

# CSS & JS — cache lunga con immutable (cambiano solo con nuova versione)
/css/*
  Cache-Control: public, max-age=604800, immutable
  Content-Type: text/css; charset=utf-8

/js/*
  Cache-Control: public, max-age=604800, immutable
  Content-Type: application/javascript; charset=utf-8

# SVG sprite
/assets/sprite.svg
  Cache-Control: public, max-age=604800, immutable
  Content-Type: image/svg+xml

# App shell — stale-while-revalidate per risposta rapida + aggiornamento background
/index.html
  Cache-Control: no-cache
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin

# Tutti gli asset generici
/*
  X-Content-Type-Options: nosniff
